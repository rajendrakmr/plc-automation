 /* ══════════════════════════════
   HAMBURGER BUTTON
══════════════════════════════ */

 .hamburger {
     display: none;
     flex-direction: column;
     justify-content: center;
     align-items: center;
     gap: 5px;

     width: 38px;
     height: 38px;

     padding: 6px;

     background: none;
     border: 1.5px solid var(--border);
     border-radius: 8px;

     cursor: pointer;

     margin-left: auto;
     flex-shrink: 0;

     transition: all 0.3s ease;
 }

 .hamburger span {
     display: block;

     width: 20px;
     height: 2px;

     background: var(--navy);

     border-radius: 2px;

     transition: all 0.3s ease;
     transform-origin: center;
 }

 /* OPEN ANIMATION */

 .hamburger.open span:nth-child(1) {
     transform: translateY(7px) rotate(45deg);
 }

 .hamburger.open span:nth-child(2) {
     opacity: 0;
     transform: scaleX(0);
 }

 .hamburger.open span:nth-child(3) {
     transform: translateY(-7px) rotate(-45deg);
 }

 /* ══════════════════════════════
   RESPONSIVE
══════════════════════════════ */

 /* Tablet & Mobile */
 @media (max-width: 992px) {
     .hamburger {
         display: flex;
     }
 }

 /* Small Mobile */
 @media (max-width: 576px) {
     .hamburger {
         width: 24px;
         height: 24px;
         padding: 5px;
         border-radius: 6px;
         left: 2px;
     }

     .hamburger span {
         width: 18px;
     }

     .hamburger.open span:nth-child(1) {
         transform: translateY(6px) rotate(45deg);
     }

     .hamburger.open span:nth-child(3) {
         transform: translateY(-6px) rotate(-45deg);
     }
 }


 /* ══════════════════════════════
   RESPONSIVE BREAKPOINTS
══════════════════════════════ */

 /* Tablet — 1024px */
