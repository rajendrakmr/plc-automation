 }

 .footer-bottom-links a {
     color: rgba(255, 255, 255, 0.45);
     text-decoration: none;
     font-family: var(--font-body);
     font-size: 0.76rem;
     transition: color 0.2s;
 }

 .footer-bottom-links a:hover {
     color: var(--orange);
 }


