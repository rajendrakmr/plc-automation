 }

 .footer-contact-item {
     display: flex;
     align-items: flex-start;
     gap: 0.55rem;
     margin-bottom: 0.55rem;
     font-family: var(--font-body);
     font-size: 0.8rem;
     color: rgba(255, 255, 255, 0.55);
 }

 .footer-col h4 {
     font-family: var(--font-extra);
     font-size: 0.76rem;
     font-weight: 600;
     text-transform: uppercase;
     letter-spacing: 1px;
     color: white;
