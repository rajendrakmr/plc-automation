 /* ── PRODUCT CATEGORIES ── */
 /* ══════════════════════════════
   CATEGORY GRID
══════════════════════════════ */

 .cats-grid {
     display: grid;
     grid-template-columns: repeat(4, 1fr);
     gap: 1.2rem;
     padding: 8px;
 }

 /* ══════════════════════════════
   CATEGORY CARD
══════════════════════════════ */

 .cat-card {
     background: var(--white);
     border: 1.5px solid var(--border);
     border-radius: 16px;

     padding: 1.8rem 1.5rem;

     cursor: pointer;

     transition: all 0.25s;

     position: relative;
     overflow: hidden;
 }

 .cat-card::after {
     content: '';

     position: absolute;
     bottom: 0;
     left: 0;
     right: 0;

     height: 4px;

     background: linear-gradient(90deg, var(--blue), var(--orange));

     transform: scaleX(0);
     transform-origin: left;

     transition: transform 0.3s;
 }

 .cat-card:hover {
     border-color: var(--blue);

     transform: translateY(-4px);

     box-shadow: var(--shadow);
 }

 .cat-card:hover::after {
     transform: scaleX(1);
 }

 /* ══════════════════════════════
   ICON
══════════════════════════════ */

 .cat-icon {
     width: 52px;
     height: 52px;

     border-radius: 12px;

     display: flex;
     align-items: center;
     justify-content: center;

     font-size: 1.5rem;

     margin-bottom: .55rem;
 }

 /* ══════════════════════════════
   TEXT
══════════════════════════════ */

 .cat-card h3 {
     font-family: 'Syne', sans-serif;
     font-size: 0.95rem;
     font-weight: 700;

     color: var(--navy);

     margin-bottom: 0.4rem;
 }

 .cat-card p {
     font-size: 0.8rem;
     color: var(--text-muted);

     line-height: 1.5;

     margin-bottom: 0.8rem;
 }

 .cat-parts {
     font-size: 0.75rem;
     color: var(--blue);

     font-weight: 600;
 }

 /* ══════════════════════════════
   RESPONSIVE
══════════════════════════════ */

 /* Laptop */
 @media (max-width: 1200px) {
     .cats-grid {
         grid-template-columns: repeat(3, 1fr);
     }
 }

 /* Tablet */
 @media (max-width: 992px) {
     .cats-grid {
         grid-template-columns: repeat(2, 1fr);
     }

     .cat-card {
         padding: 1.5rem 1.25rem;
     }
 }

 /* Mobile */
 @media (max-width: 576px) {
     .cats-grid {
         grid-template-columns: 1fr;
         gap: 1rem;
         width: 100%;
         display: block;
         margin-bottom: 10px;
     }

     .cat-card {
         padding: 1.2rem;
         border-radius: 14px;
     }

     .cat-icon {
         width: 46px;
         height: 46px;

         font-size: 1.25rem;

         margin-bottom: 0.8rem;
     }

     .cat-card h3 {
         font-size: 0.9rem;
     }

     .cat-card p {
         font-size: 0.78rem;
     }

     .cat-parts {
         font-size: 0.72rem;
     }

     /* Disable hover lift on mobile */
     .cat-card:hover {
         transform: none;
     }
 }

 /* ── FEATURES ── */
 .features-section {
     background: var(--navy);
     color: white;
 }

 .features-grid {
     display: grid;
     grid-template-columns: repeat(3, 1fr);
     gap: 2rem;
 }

 .feat-card {
     background: rgba(255, 255, 255, 0.05);
     border: 1px solid rgba(255, 255, 255, 0.08);
     border-radius: 16px;
     padding: 2rem;
     transition: background 0.2s;
 }

 .feat-card:hover {
     background: rgba(255, 255, 255, 0.09);
 }

 .feat-num {
     font-family: 'Syne', sans-serif;
     font-size: 2.5rem;
     font-weight: 800;
     color: var(--orange);
     line-height: 1;
     margin-bottom: 0.3rem;
 }

 .feat-card h3 {
     font-family: 'Syne', sans-serif;
     font-size: 1.05rem;
     font-weight: 700;
     margin-bottom: 0.6rem;
 }

 .feat-card p {
     font-size: 0.85rem;
     color: rgba(255, 255, 255, 0.6);
     line-height: 1.6;
 }

 /* ── HOW IT WORKS ── */
 .how-grid {
     display: grid;
     grid-template-columns: repeat(4, 1fr);
     gap: 2rem;
     position: relative;
 }

 .how-grid::before {
     content: '';
     position: absolute;
     top: 35px;
     left: 12.5%;
     right: 12.5%;
     height: 2px;
     background: linear-gradient(90deg, var(--blue), var(--orange));
     z-index: 0;
 }

 .how-card {
     text-align: center;
     position: relative;
     z-index: 1;
 }

 .how-num {
     width: 70px;
     height: 70px;
     background: white;
     border: 3px solid var(--blue);
     border-radius: 50%;
     display: flex;
     align-items: center;
     justify-content: center;
     font-family: 'Syne', sans-serif;
     font-size: 1.3rem;
     font-weight: 800;
     color: var(--blue);
     margin: 0 auto 1.2rem;
     box-shadow: var(--shadow);
 }

 .how-card h3 {
     font-family: 'Syne', sans-serif;
     font-weight: 700;
     font-size: 0.95rem;
     color: var(--navy);
     margin-bottom: 0.4rem;
 }

 .how-card p {
     font-size: 0.82rem;
     color: var(--text-muted);
     line-height: 1.5;
 }

 /* ── TESTIMONIALS ── */
 .testi-section {
     background: var(--bg);
 }

