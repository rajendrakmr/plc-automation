 /* ═══════════════════════════════════════════════════
   GOOGLE FONTS
═══════════════════════════════════════════════════ */
 @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Manrope:wght@400;500;600&family=Poppins:wght@500;600;700&display=swap');


 /* ═══════════════════════════════════════════════════
   DESIGN TOKENS
═══════════════════════════════════════════════════ */
 :root {
     --white: #FFFFFF;
     --grey: #F8FAFC;
     --blue: #05339C;
     --font: 0.875rem;
     --light-blue: #1A2CA3;
     --hover-blue: #1A2CA3;
     --text-color: #23364c;
     --p-blue-color: #0e60ca;
     --p-btn-color: #cfa64f;
     --p-bgw-color: #fefefe;
     --p-hover-color: #0e60ca;

     --p-bgg-color: #f8f8f8;

     /* Brand */
     --primary: #0170c2;
     --blue: #1a4fd6;
     --blue-light: #2563eb;
     --logo-blue: #0066CC;
     --logo-blue-light: #1a7ae0;
     --logo-blue-dark: #0052a3;

     /* Navy */
     --navy: #0B1F3A;
     --navy-mid: #132040;
     --navy-light: #1a2d4d;

     /* Orange */
     --orange: #f97316;
     --orange-light: #fb923c;
     --orange-dark: #ea580c;

     /* Steel */
     --steel: #64748b;
     --steel-light: #94a3b8;
     --steel-dark: #475569;

     /* Backgrounds */
     --bg: #f0f4ff;
     --bg-warm: #f8fafc;
     --card-bg: #ffffff;
     --white: #ffffff;

     /* Text */
     --text: #0f172a;
     --text-muted: #475569;
     --text-light-muted: #8fa6c7;
     --text-white: #ffffff;

     /* Status */
     --success: #10b981;
     --warning: #f59e0b;
     --warn: #f59e0b;
     --danger: #ef4444;

     /* Shadows */
     --shadow: 0 4px 24px rgba(11, 31, 58, 0.10);
     --shadow-lg: 0 12px 48px rgba(11, 31, 58, 0.18);
     --shadow-blue: 0 8px 32px rgba(0, 102, 204, 0.15);

     /* Borders */
     --border: #e2e8f0;
     --border-blue: rgba(0, 102, 204, 0.15);

     /* Gradients */
     --gradient-hero: linear-gradient(135deg, #0B1F3A 0%, #0066CC 100%);
     --gradient-card: linear-gradient(135deg, #0066CC 0%, #1a7ae0 100%);
     --gradient-orange: linear-gradient(135deg, #f97316 0%, #ea580c 100%);

     /* Radius */
     --radius-sm: 6px;
     --radius: 12px;
     --radius-lg: 20px;

     /* Typography */
     --font-heading: 'Inter', sans-serif;
     --font-body: 'Manrope', sans-serif;
     --font-extra: 'Poppins', sans-serif;

     /* Spacing scale */
     --space-xs: 0.25rem;
     --space-sm: 0.5rem;
     --space-md: 1rem;
     --space-lg: 1.5rem;
     --space-xl: 2rem;
     --space-2xl: 3rem;
     --space-3xl: 5rem;

     /* Layout */
     --max-width: 1300px;
     --header-h: 76px;
     --header-mh: 120px;
 }


 /* ═══════════════════════════════════════════════════
   RESET
═══════════════════════════════════════════════════ */
 *,
 *::before,
 *::after {
     box-sizing: border-box;
     margin: 0;
     padding: 0;
 }

 html {
     scroll-behavior: smooth;
     -webkit-text-size-adjust: 100%;
 }

 body {
     font-family: var(--font-body);
     font-size: 0.875rem;
     line-height: 1.65;
     color: var(--text);
     background: var(--grey);
     overflow-x: hidden;
     -webkit-font-smoothing: antialiased;
     -moz-osx-font-smoothing: grayscale;
 }

 img,
 video,
 svg {
     display: block;
     max-width: 100%;
 }

 a {
     color: inherit;
     text-decoration: none;
 }

 ul,
 ol {
     list-style: none;
 }

 button {
     cursor: pointer;
     border: none;
     background: none;
 }

 input,
 textarea,
 select {
     font-family: var(--font-body);
     font-size: 1rem;
 }

 button {
     cursor: pointer;
     border: none;
     background: none;
 }

 input,
 textarea,
 select {
     font-family: var(--font-body);
     font-size: 1rem;
 }

 /* ═══════════════════════════════════════════════════
   TYPOGRAPHY
═══════════════════════════════════════════════════ */
 h1,
 h2 {
     font-family: var(--font-extra);
     font-weight: 600;
     color: rgb(32 46 63);
 }

 h3 {
     font-size: clamp(1.1rem, 2vw, 1.4rem);
 }

 h4 {
     font-size: 1rem;
 }

 h5 {
     font-size: 0.9rem;
 }

 h6 {
     font-size: 0.82rem;
 }

 p {
     font-family: var(--font-body);
     color: var(--text-muted);
     line-height: 1.7;
 }

 .text-sm {
     font-size: 0.82rem;
 }

 .text-xs {
     font-size: 0.72rem;
 }

 .text-muted {
     color: var(--text-muted);
 }

 .text-white {
     color: var(--white);
 }

 .text-orange {
     color: var(--orange);
 }

 .text-navy {
     color: var(--navy);
 }

 .text-blue {
     color: var(--blue);
 }

 .font-heading {
     font-family: var(--font-heading);
 }

 .font-extra {
     font-family: var(--font-extra);
 }

 /* ═══════════════════════════════════════════════════
   LAYOUT HELPERS
═══════════════════════════════════════════════════ */

 .container {
     width: 100%;
     max-width: var(--max-width);
     margin-inline: auto;
     padding-inline: var(--space-xl);
 }


 .section {
     padding-block: var(--space-3xl);
 }

 .section-header {
     display: flex;
     justify-content: space-between;
     align-items: flex-end;
     gap: var(--space-md);
     margin-bottom: var(--space-2xl);
     flex-wrap: wrap;
 }

 /* Section header block */
 .section-header {
     display: flex;
     justify-content: space-between;
     align-items: flex-end;
     gap: var(--space-md);
     margin-bottom: var(--space-2xl);
     flex-wrap: wrap;
     /* padding: 8px */
 }

 .section-tag {
     display: inline-block;
     font-family: var(--font-extra);
     font-size: 0.72rem;
     font-weight: 600;
     text-transform: uppercase;
     letter-spacing: 2px;
     color: var(--orange);
     margin-bottom: 0.4rem;
 }

 .section-title {
     font-family: var(--font-heading);
     font-size: 1.75rem;
     font-weight: 700;
     color: var(--navy);
     line-height: 1.2;
     letter-spacing: -0.5px;
     /* margin-bottom: 0.6rem; */
 }

 .section-sub {
     font-family: var(--font-body);
     font-size: 1rem;
     color: var(--text-muted);
     max-width: 560px;
     line-height: 1.65;
 }

 .section-sub-hub {
     padding-top: 14px;
     font-size: 1rem;
     color: var(--text-muted);
     line-height: 1.65;
 }

 .section-sub-title {
     padding-bottom: 10px;
     font-size: 0.95rem;
     color: var(--text-light-muted);
     line-height: 1.65;
 }

 /* View-all link */
 .view-all {
     display: inline-flex;
     align-items: center;
     gap: 0.4rem;
     font-family: var(--font-extra);
     font-size: 0.82rem;
     font-weight: 600;
     color: var(--blue);
     text-decoration: none;
     transition: gap 0.2s ease;
     white-space: nowrap;
 }

 .view-all:hover {
     gap: 0.7rem;
 }


 /* =========================
   FIXED HEADER WRAPPER
========================= */

 .site-header-wrap {
     position: fixed;
     top: 0;
     left: 0;
     width: 100%;
     z-index: 9999;
     background: var(--white);

 }

 /* =========================
   TOPBAR
========================= */


 /* Buttons */
 .btn-quote {
     font-family: var(--font-extra);
     font-size: 0.78rem;
     font-weight: 600;
     text-transform: uppercase;
     letter-spacing: 0.5px;
     background: var(--orange);
     color: white;
     border: none;
     border-radius: var(--radius-sm);
     padding: 0.5rem 1.1rem;
     cursor: pointer;
     white-space: nowrap;
     transition: background 0.2s, transform 0.15s;
 }

 .btn-quote:hover {
     background: var(--orange-dark);
     transform: translateY(-1px);
 }

 .admin-link {
     font-family: var(--font-extra);
     font-size: 0.78rem;
     font-weight: 600;
     text-transform: uppercase;
     letter-spacing: 0.5px;
     display: flex;
     align-items: center;
     gap: 0.4rem;
     background: var(--navy);
     color: white;
     border: none;
     border-radius: var(--radius-sm);
     padding: 0.5rem 0.9rem;
     cursor: pointer;
     text-decoration: none;
     transition: background 0.2s;
 }

 .admin-link:hover {
     background: var(--blue);
 }


 /* ═══════════════════════════════════════════════════
   HAMBURGER
═══════════════════════════════════════════════════ */
 .hamburger {
     display: none;
     flex-direction: column;
     justify-content: center;
     gap: 5px;
     width: 38px;
     height: 38px;
     padding: 7px;
     background: none;
     border: 1.5px solid var(--border);
     border-radius: var(--radius-sm);
     cursor: pointer;
     margin-left: auto;
     flex-shrink: 0;
 }


 /* ═══════════════════════════════════════════════════
   HERO
═══════════════════════════════════════════════════ */
 .hero {
     background: linear-gradient(135deg, var(--navy) 0%, #0f2555 60%, #1a3a7a 100%);
     color: white;
     padding: var(--space-3xl) var(--space-xl);
     position: relative;
     overflow: hidden;
 }

 .hero::before {
     content: '';
     position: absolute;
     inset: 0;
     background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/svg%3E");
     pointer-events: none;
 }

 .hero-inner {
     max-width: var(--max-width);
     margin-inline: auto;
     display: grid;
     grid-template-columns: 1fr 1fr;
     gap: 4rem;
     align-items: center;
     position: relative;
     z-index: 1;
 }

 /* Hero badge */
 .hero-badge {
     display: inline-flex;
     align-items: center;
     gap: 0.5rem;
     background: rgba(249, 115, 22, 0.15);
     border: 1px solid rgba(249, 115, 22, 0.4);
     color: var(--orange);
     padding: 0.35rem 0.9rem;
     border-radius: 50px;
     font-family: var(--font-extra);
     font-size: 0.72rem;
     font-weight: 600;
     letter-spacing: 0.5px;
     text-transform: uppercase;
     margin-bottom: var(--space-lg);
 }

 .hero-badge span {
     width: 6px;
     height: 6px;
     background: var(--orange);
     border-radius: 50%;
     flex-shrink: 0;
     animation: pulse 2s ease-in-out infinite;
 }

 @keyframes pulse {

     0%,
     100% {
         opacity: 1;
     }

     50% {
         opacity: 0.3;
     }
 }

 .hero h1 {
     font-family: var(--font-heading);
     /* font-size: clamp(2.2rem, 4vw, 3.2rem); */
     /* font-weight: 800; */
     line-height: 1.1;
     letter-spacing: -1px;
     color: white;
     margin-bottom: 1.1rem;
 }

 .hero h1 em {
     color: var(--orange);
     font-style: normal;
 }

 .hero p {
     font-family: var(--font-body);
     font-size: 1.05rem;
     color: rgba(255, 255, 255, 0.75);
     line-height: 1.7;
     margin-bottom: var(--space-xl);
     max-width: 480px;
 }

 .hero-actions {
     display: flex;
     gap: var(--space-md);
     flex-wrap: wrap;
 }

 .btn-primary {
     /* background: var(--orange); */
     color: white;
     padding: 0.85rem 2rem;
     border-radius: 10px;
     font-family: var(--font-extra);
     font-weight: 700;
     font-size: 0.88rem;
     text-decoration: none;
     text-transform: uppercase;
     letter-spacing: 0.5px;
     display: inline-flex;
     align-items: center;
     gap: 0.5rem;
     border: none;
     cursor: pointer;
     transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
 }

 .btn-primary:hover {
     background: var(--hover-blue);
     transform: translateY(-2px);
     box-shadow: 0 8px 24px rgba(247, 121, 32, 0.3);
 }

 .btn-secondary {
     background: rgba(255, 255, 255, 0.08);
     color: white;
     border: 1.5px solid rgba(255, 255, 255, 0.25);
     padding: 0.85rem 2rem;
     border-radius: 10px;
     font-family: var(--font-extra);
     font-weight: 600;
     font-size: 0.88rem;
     text-decoration: none;
     text-transform: uppercase;
     letter-spacing: 0.5px;
     display: inline-flex;
     align-items: center;
     gap: 0.5rem;
     transition: background 0.2s, border-color 0.2s;
 }

 .btn-secondary:hover {
     background: rgba(255, 255, 255, 0.15);
     border-color: white;
 }

 /* Hero stats */
 .hero-stats {
     display: flex;
     gap: var(--space-xl);
     margin-top: 2.5rem;
     padding-top: var(--space-xl);
     border-top: 1px solid rgba(255, 255, 255, 0.1);
     flex-wrap: wrap;
 }

 .stat-item {
     text-align: left;
 }

 .stat-num {
     font-family: var(--font-heading);
     font-size: 1.8rem;
     font-weight: 800;
     color: var(--orange);
     line-height: 1;
 }

 .stat-label {
     font-family: var(--font-body);
     font-size: 0.76rem;
     color: rgba(255, 255, 255, 0.55);
     margin-top: 0.2rem;
 }

 /* Hero right card */
 .hero-right {
     background: var(--navy);
     border-radius: 24px;
     padding: 1.5rem;
     color: var(--white);
 }

 .hero-search-card h3 {
     font-family: var(--font-heading);
     font-size: 1.15rem;
     font-weight: 700;
     color: white;
     margin-bottom: 0.4rem;
 }

 .hero-search-card p {
     font-family: var(--font-body);
     font-size: 0.84rem;
     color: rgba(255, 255, 255, 0.6);
     margin-bottom: var(--space-lg);
 }

 .part-search {
     background: white;
     border-radius: var(--radius);
     padding: 0.35rem;
     display: flex;
     gap: 0.4rem;
     margin-bottom: var(--space-md);
 }

 .part-search input {
     flex: 1;
     border: none;
     padding: 0.65rem 0.75rem;
     font-family: var(--font-body);
     font-size: 0.88rem;
     color: var(--text);
     outline: none;
     background: none;
 }

 .part-search button {
     background: var(--orange);
     color: white;
     border: none;
     border-radius: var(--radius-sm);
     padding: 0.65rem 1.1rem;
     font-family: var(--font-extra);
     font-weight: 600;
     font-size: 0.82rem;
     cursor: pointer;
     white-space: nowrap;
     transition: background 0.2s;
 }

 .part-search button:hover {
     background: var(--orange-dark);
 }

 .popular-brands {
     display: flex;
     flex-wrap: wrap;
     gap: 0.45rem;
 }

 .brand-tag {
     background: rgba(255, 255, 255, 0.1);
     border: 1px solid rgba(255, 255, 255, 0.2);
     color: rgba(255, 255, 255, 0.8);
     padding: 0.28rem 0.75rem;
     border-radius: 50px;
     font-family: var(--font-body);
     font-size: 0.73rem;
     cursor: pointer;
     transition: background 0.2s, border-color 0.2s, color 0.2s;
 }

 .brand-tag:hover {
     background: var(--orange);
     border-color: var(--orange);
     color: white;
 }

 .quick-links {
     margin-top: var(--space-lg);
     display: grid;
     grid-template-columns: 1fr 1fr;
     gap: 0.55rem;
 }

 .quick-link-item {
     background: rgba(255, 255, 255, 0.07);
     border: 1px solid rgba(255, 255, 255, 0.1);
     border-radius: 10px;
     padding: 0.75rem;
     cursor: pointer;
     display: flex;
     align-items: center;
     gap: 0.6rem;
     transition: background 0.2s, border-color 0.2s;
 }

 .quick-link-item:hover {
     background: rgba(255, 255, 255, 0.13);
     border-color: var(--orange);
 }

 .ql-icon {
     width: 32px;
     height: 32px;
     background: rgba(249, 115, 22, 0.2);
     border-radius: var(--radius-sm);
     display: flex;
     align-items: center;
     justify-content: center;
     font-size: 1rem;
     flex-shrink: 0;
 }

 .ql-text strong {
     display: block;
     font-family: var(--font-extra);
     font-size: 0.76rem;
     font-weight: 600;
     color: white;
 }

 .ql-text span {
     font-family: var(--font-body);
     font-size: 0.68rem;
     color: rgba(255, 255, 255, 0.5);
 }


 /* ═══════════════════════════════════════════════════
   TRUST BAR
═══════════════════════════════════════════════════ */
 .trust-bar {
     background: var(--white);
     border-bottom: 1px solid var(--border);
     padding: 0.9rem var(--space-xl);
 }

 .trust-bar-inner {
     max-width: var(--max-width);
     margin-inline: auto;
     display: flex;
     align-items: center;
     gap: var(--space-xl);
     flex-wrap: wrap;
     justify-content: space-between;
 }

 .trust-item {
     display: flex;
     align-items: center;
     gap: 0.55rem;
     font-family: var(--font-body);
     font-size: 0.8rem;
     color: var(--text-muted);
 }

 .trust-item svg {
     width: 18px;
     height: 18px;
     fill: var(--blue);
     flex-shrink: 0;
 }

 .trust-item strong {
     font-family: var(--font-extra);
     font-weight: 600;
     color: var(--text);
 }


 /* ═══════════════════════════════════════════════════
   BUTTONS — GLOBAL
═══════════════════════════════════════════════════ */
 .btn {
     display: inline-flex;
     align-items: center;
     justify-content: center;
     gap: 0.4rem;
     font-family: var(--font-extra);
     font-size: 0.82rem;
     font-weight: 600;
     text-transform: uppercase;
     letter-spacing: 0.4px;
     border: none;
     border-radius: var(--radius-sm);
     padding: 0.6rem 1.2rem;
     cursor: pointer;
     white-space: nowrap;
     text-decoration: none;
     transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
 }

 .btn-sm {
     padding: 0.4rem 0.85rem;
     font-size: 0.75rem;
 }

 .btn-lg {
     padding: 0.9rem 2rem;
     font-size: 0.9rem;
 }

 .btn-orange {
     background: var(--orange);
     color: white;
 }

 .btn-orange:hover {
     background: var(--orange-dark);
     transform: translateY(-1px);
 }

 .btn-navy {
     background: var(--navy);
     color: white;
 }

 .btn-navy:hover {
     background: var(--blue);
 }

 .btn-outline {
     background: transparent;
     color: var(--navy);
     border: 1.5px solid var(--border);
 }

 .btn-outline:hover {
     border-color: var(--blue);
     color: var(--blue);
 }

 .btn-white {
     background: white;
     color: var(--orange-dark);
 }

 .btn-white:hover {
     transform: translateY(-2px);
     box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
 }

 .btn-outline-white {
     background: transparent;
     color: white;
     border: 2px solid white;
 }

 .btn-outline-white:hover {
     background: white;
     color: var(--orange-dark);
 }


 /* ═══════════════════════════════════════════════════
   BADGES / TAGS
═══════════════════════════════════════════════════ */
 .badge {
     display: inline-flex;
     align-items: center;
     font-family: var(--font-extra);
     font-size: 0.65rem;
     font-weight: 600;
     text-transform: uppercase;
     letter-spacing: 0.5px;
     padding: 0.22rem 0.6rem;
     border-radius: 50px;
 }

 .badge-success {
     background: rgba(16, 185, 129, 0.12);
     color: #065f46;
 }

 .badge-warning {
     background: rgba(245, 158, 11, 0.12);
     color: #92400e;
 }

 .badge-danger {
     background: rgba(239, 68, 68, 0.12);
     color: #991b1b;
 }

 .badge-blue {
     background: rgba(26, 79, 214, 0.1);
     color: var(--blue);
 }

 .badge-navy {
     background: var(--navy);
     color: white;
 }

 .badge-orange {
     background: var(--orange);
     color: white;
 }


 /* ═══════════════════════════════════════════════════
   CARDS
═══════════════════════════════════════════════════ */
 .card {
     background: var(--card-bg);
     border: 1.5px solid var(--border);
     border-radius: var(--radius-lg);
     overflow: hidden;
     transition: transform 0.28s cubic-bezier(0.4, 0, 0.2, 1),
         box-shadow 0.28s cubic-bezier(0.4, 0, 0.2, 1),
         border-color 0.2s;
 }

 .card:hover {
     transform: translateY(-5px);
     box-shadow: var(--shadow-lg);
     border-color: var(--blue);
 }

 .card-body {
     padding: 1.4rem;
 }

 .card-footer {
     padding: 0.9rem 1.4rem;
     border-top: 1px solid var(--border);
     display: flex;
     align-items: center;
     justify-content: space-between;
     gap: 0.75rem;
 }


 /* ═══════════════════════════════════════════════════
   FORM ELEMENTS
═══════════════════════════════════════════════════ */
 .form-group {
     display: flex;
     flex-direction: column;
     gap: 0.4rem;
     margin-bottom: .55rem;
 }

 .form-label {
     font-family: var(--font-extra);
     font-size: 0.78rem;
     font-weight: 600;
     color: var(--text);
 }

 .form-input,
 .form-select,
 .form-textarea {
     width: 100%;
     padding: 0.65rem 0.9rem;
     font-family: var(--font-body);
     font-size: 0.88rem;
     color: var(--text);
     background: var(--white);
     border: 1.5px solid var(--border);
     border-radius: var(--radius-sm);
     outline: none;
     transition: border-color 0.2s, box-shadow 0.2s;
     appearance: none;
 }

 .form-input:focus,
 .form-select:focus,
 .form-textarea:focus {
     border-color: var(--blue);
     box-shadow: 0 0 0 3px rgba(26, 79, 214, 0.1);
 }

 .form-textarea {
     min-height: 110px;
     resize: vertical;
 }

 .form-row {
     display: flex;
     gap: 0.85rem;
 }

 .form-row>* {
     flex: 1;
 }


 /* ═══════════════════════════════════════════════════
   STATUS / STOCK
═══════════════════════════════════════════════════ */
 .status-badge {
     display: inline-flex;
     align-items: center;
     font-family: var(--font-extra);
     font-size: 0.65rem;
     font-weight: 700;
     text-transform: uppercase;
     letter-spacing: 0.5px;
     padding: 0.2rem 0.55rem;
     border-radius: 50px;
 }

 .status-in-stock {
     background: rgba(16, 185, 129, 0.12);
     color: #065f46;
 }

 .status-low-stock {
     background: rgba(245, 158, 11, 0.12);
     color: #92400e;
 }

 .status-out-of-stock {
     background: rgba(239, 68, 68, 0.12);
     color: #991b1b;
 }

 .status-pending {
     background: rgba(245, 158, 11, 0.15);
     color: var(--warn);
 }

 .status-fulfilled {
     background: rgba(16, 185, 129, 0.15);
     color: var(--success);
 }

 .status-processing {
     background: rgba(26, 79, 214, 0.15);
     color: #60a5fa;
 }

 .status-cancelled {
     background: rgba(239, 68, 68, 0.15);
     color: var(--danger);
 }


 /* ═══════════════════════════════════════════════════
   SOCIAL ICONS
═══════════════════════════════════════════════════ */
 .social-icons {
     display: flex;
     align-items: center;
     gap: 0.5rem;
 }

 .social-icons a {
     width: 30px;
     height: 30px;
     display: flex;
     align-items: center;
     justify-content: center;
     background: rgba(255, 255, 255, 0.08);
     border-radius: 6px;
     color: var(--steel-light);
     font-size: 0.8rem;
     text-decoration: none;
     transition: background 0.2s, color 0.2s, transform 0.2s;
 }

 .social-icons a:hover {
     background: var(--orange);
     color: white;
     transform: translateY(-2px);
 }


 /* ═══════════════════════════════════════════════════
   PAGINATION
═══════════════════════════════════════════════════ */
 .pagination {
     display: flex;
     align-items: center;
     justify-content: center;
     gap: 0.4rem;
     margin-top: var(--space-2xl);
     flex-wrap: wrap;
 }

 .page-btn {
     min-width: 36px;
     height: 36px;
     padding: 0 0.6rem;
     display: inline-flex;
     align-items: center;
     justify-content: center;
     font-family: var(--font-extra);
     font-size: 0.82rem;
     font-weight: 600;
     border-radius: var(--radius-sm);
     border: 1.5px solid var(--border);
     background: var(--white);
     color: var(--text-muted);
     cursor: pointer;
     transition: background 0.2s, border-color 0.2s, color 0.2s;
 }

 .page-btn:hover {
     background: var(--bg);
     border-color: var(--blue);
     color: var(--blue);
 }

 .page-btn.active {
     background: var(--blue);
     border-color: var(--blue);
     color: white;
 }

 .page-btn:disabled {
     opacity: 0.4;
     cursor: not-allowed;
     pointer-events: none;
 }


 /* ═══════════════════════════════════════════════════
   FOOTER
═══════════════════════════════════════════════════ */
