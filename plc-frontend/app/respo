 /* ══════════════════════════════
   MOBILE MENU — SMOOTH ANIMATION
══════════════════════════════ */
 /* Override previous mob-submenu — use max-height transition */
 .mob-submenu {
     display: block !important;
     /* override previous display:none */
     max-height: 0;
     overflow: hidden;
     background: var(--white);
     border-top: none;
     transition: max-height 0.38s cubic-bezier(0.4, 0, 0.2, 1),
         opacity 0.3s ease,
         padding 0.25s ease;
     opacity: 1;
     padding-top: 0;
     padding-bottom: 0;
 }

 .mob-item.open .mob-submenu {
     max-height: 600px;
     opacity: 1;
     padding-top: 0.4rem;
     padding-bottom: 0.6rem;
 }

 .mob-item.open .mob-link {
     color: var(--blue);
     background: rgba(26, 79, 214, 0.04);
 }

 .mob-arrow {
     display: inline-block;
     transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
 }

 .mob-item.open .mob-arrow {
     transform: rotate(90deg);
 }

 /* ══════════════════════════════
   SPLIT PROMO SECTION
══════════════════════════════ */

 .split-section {

     width: 100%;

     padding: clamp(50px, 6vw, 90px) clamp(20px, 5vw, 72px);

     background: var(--white);

     overflow: hidden;
 }

 .split-inner {

     max-width: 1300px;

     margin: 0 auto;

     display: grid;

     grid-template-columns: repeat(2, minmax(0, 1fr));

     gap: clamp(30px, 5vw, 80px);

     align-items: center;
 }


 /* ======================
   CONTENT
====================== */

 .split-title {

     font-family: 'Syne', sans-serif;

     font-size: clamp(1.8rem, 3vw, 2.8rem);

     font-weight: 800;

     line-height: 1.2;

     letter-spacing: -0.5px;

     margin: .5rem 0 1rem;
 }

 .split-highlight {

     color: var(--blue);

     position: relative;
 }

 .split-highlight::after {

     content: "";

     position: absolute;

     left: 0;
     right: 0;

     bottom: -4px;

     height: 3px;

     border-radius: 10px;

     background:
         linear-gradient(90deg,
             var(--blue),
             var(--blue-light));
 }

