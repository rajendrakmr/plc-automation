 /* ═══════════════════════════════════════════════════
   RESPONSIVE BREAKPOINTS
═══════════════════════════════════════════════════ */

 /* ── 1200px — Large tablets / small laptops ── */
 @media (max-width: 1200px) {
     :root {
         --max-width: 100%;
     }
 }

 /* ── 1024px — Tablet landscape ── */
 @media (max-width: 1024px) {
     .topbar {
         display: none;
     }

     .hero-inner {
         grid-template-columns: 1fr;
         gap: 2.5rem;
     }

     .trust-bar-inner {
         gap: var(--space-lg);
     }

     .footer-grid {
         grid-template-columns: 1fr 1fr;
         gap: 2rem;
     }

     .search-box {
         display: none;
     }

     .mega-grid {
         grid-template-columns: 1fr 1fr;
     }
 }

 /* ── 900px — Nav hides, hamburger shows ── */
 @media (max-width: 900px) {
     nav {
         display: none;
     }

     .header-actions {
         display: none;
     }

     .hamburger {
         display: flex;
     }

     .mega-menu,
     .dropdown {
         display: none !important;
     }
 }

 /* ── 768px — Mobile ── */
 @media (max-width: 768px) {
     :root {
         --space-3xl: 3rem;
         --space-2xl: 2rem;
     }

     .hero {
         padding: 2.5rem 1.2rem;
     }

     .hero h1 {
         font-size: 1.85rem;
     }

     .hero p {
         font-size: 0.95rem;
     }

     .hero-stats {
         gap: var(--space-lg);
     }

     .stat-num {
         font-size: 1.4rem;
     }

     .section {
         padding: 2.5rem 1.2rem;
     }

     .section-header {
         flex-direction: column;
         align-items: flex-start;
     }

     .trust-bar {
         padding: 0.9rem 1.2rem;
     }

     .trust-bar-inner {
         flex-direction: column;
         gap: 0.75rem;
         align-items: flex-start;
     }

     .footer-grid {
         grid-template-columns: 1fr;
         gap: 2rem;
     }

     .footer-bottom {
         flex-direction: column;
         text-align: center;
     }

     .footer-bottom-links {
         justify-content: center;
     }

     .form-row {
         flex-direction: column;
     }

     .quick-links {
         grid-template-columns: 1fr;
     }

     .cta-btns {
         display: flex;
         flex-direction: column;
         align-items: center;
         gap: 0.75rem;
     }
 }

 /* ── 480px — Small mobile ── */
 @media (max-width: 480px) {
     .hero h1 {
         font-size: 1.6rem;
     }

     .hero-stats {
         flex-wrap: wrap;
         gap: var(--space-md);
     }

     .hero-badge {
         font-size: 0.65rem;
         padding: 0.3rem 0.7rem;
     }

     .part-search {
         flex-direction: column;
     }

     .part-search button {
         width: 100%;
     }

     .btn-primary,
     .btn-secondary {
         width: 100%;
         justify-content: center;
     }

     .pagination {
         gap: 0.25rem;
     }

     .page-btn {
         min-width: 32px;
         height: 32px;
         font-size: 0.76rem;
     }
 }

 /* REsponsive code */



 /* ── Card shell ── */
 .pc-card {
     background: var(--card-bg, #ffffff);
     border: 1.5px solid var(--border, #e2e8f0);
     border-radius: var(--radius-lg, 20px);
     overflow: hidden;
     display: flex;
     flex-direction: column;
     transition: transform 0.28s cubic-bezier(0.4, 0, 0.2, 1),
         box-shadow 0.28s cubic-bezier(0.4, 0, 0.2, 1),
         border-color 0.2s;
     position: relative;
 }

 .pc-card:hover {
     transform: translateY(-6px);
     box-shadow: var(--shadow-lg, 0 12px 48px rgba(10, 22, 40, 0.18));
     border-color: var(--blue, #1a4fd6);
 }

 /* ── Image area ── */
 .pc-img-wrap {
     position: relative;
     height: 200px;
     background: var(--bg, #f0f4ff);
     overflow: hidden;
     flex-shrink: 0;
 }

 .pc-img {
     width: 100%;
     height: 100%;
     object-fit: cover;
     transition: transform 0.38s cubic-bezier(0.4, 0, 0.2, 1);
     display: block;
 }

 .pc-card:hover .pc-img {
     transform: scale(1.06);
 }

 .pc-img-fallback {
     width: 100%;
     height: 100%;
     display: flex;
     align-items: center;
     justify-content: center;
     font-size: 3rem;
     color: var(--steel-light, #94a3b8);
     background: var(--bg, #f0f4ff);
 }

 /* ── Category badge ── */
 .pc-category {
     position: absolute;
     top: 0.75rem;
     left: 0.75rem;
     background: var(--navy, #0B1F3A);
     color: #fff;
     font-family: 'Syne', sans-serif;
     font-size: 0.62rem;
     font-weight: 700;
     text-transform: uppercase;
     letter-spacing: 0.8px;
     padding: 0.25rem 0.6rem;
     border-radius: 50px;
     pointer-events: none;
 }

 /* ── Quick-view overlay ── */
 .pc-overlay {
     position: absolute;
     inset: 0;
     background: rgba(11, 31, 58, 0.55);
     display: flex;
     align-items: center;
     justify-content: center;
     opacity: 0;
     transition: opacity 0.25s ease;
 }

 .pc-card:hover .pc-overlay {
     opacity: 1;
 }

 .pc-quick-view {
     background: #fff;
     color: var(--navy, #0B1F3A);
     font-family: 'Syne', sans-serif;
     font-size: 0.78rem;
     font-weight: 700;
     text-transform: uppercase;
     letter-spacing: 0.5px;
     padding: 0.55rem 1.2rem;
     border-radius: 8px;
     text-decoration: none;
     transform: translateY(8px);
     transition: transform 0.25s ease, background 0.2s;
 }

 .pc-card:hover .pc-quick-view {
     transform: translateY(0);
 }

 .pc-quick-view:hover {
     background: var(--orange, #f97316);
     color: #fff;
 }

 /* ── Card body ── */
 .pc-body {
     padding: 1.1rem 1.2rem 1.2rem;
     display: flex;
     flex-direction: column;
     flex: 1;
     gap: 0.4rem;
 }

 /* ── Meta row ── */
 .pc-meta {
     display: flex;
     align-items: center;
     justify-content: space-between;
     gap: 0.5rem;
 }

 .pc-brand {
     font-size: 0.72rem;
     font-weight: 700;
     text-transform: uppercase;
     letter-spacing: 0.8px;
     color: var(--steel, #64748b);
 }

 /* ── Stock badges ── */
 .badge-stock {
     font-size: 0.65rem;
     font-weight: 700;
     text-transform: uppercase;
     letter-spacing: 0.5px;
     padding: 0.2rem 0.55rem;
     border-radius: 50px;
     flex-shrink: 0;
 }

 .badge-in {
     color: #ffffff;
     background: #00a918;
     font-weight: 900;
 }

 .badge-low {
     background: rgb(237, 108, 2);
     ;
     color: rgb(255, 255, 255);
 }

 .badge-out {
     background: rgb(211, 47, 47);
     ;
     color: rgb(255, 255, 255);
     ;
 }

 /* ── BRANDS GRID ── */
 .brands-section {
     background: white;
 }

 .brands-grid {
     display: grid;
     grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
     gap: 1px;
     background: var(--white);
     border: 1px solid var(--border);
     border-radius: 16px;
     overflow: hidden;
     padding: 1.2rem;
 }

 .brand-card {
     background: white;
     padding: 1.8rem 1rem;
     display: flex;
     flex-direction: column;
     align-items: center;
     gap: 0.6rem;
     cursor: pointer;
     transition: background 0.2s, transform 0.2s;
     text-align: center;
 }

 .brand-card:hover {
     background: var(--bg);
 }

