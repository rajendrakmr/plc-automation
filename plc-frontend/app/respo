     display: grid;
     grid-template-columns: 2fr 1fr 1fr 1fr;
     gap: 3rem;
     margin-bottom: var(--space-2xl);
 }

 .footer-brand p {
     font-family: var(--font-body);
     font-size: 0.84rem;
     line-height: 1.7;
     margin-top: var(--space-md);
     margin-bottom: 1.1rem;
